# CloudTutor local runtime defaults
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8080
FRONTEND_PORT=4173
FRONTEND_NEXT_PORT=4174
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8080

# Session 10 deployment helpers
GCP_PROJECT=cloudtutor-490215
GCP_REGION=us-central1
# RUNTIME_SERVICE_ACCOUNT_ID=cloudtutor-backend-sa
# RUNTIME_SERVICE_ACCOUNT_EMAIL=cloudtutor-backend-sa@cloudtutor-490215.iam.gserviceaccount.com
# CLOUD_RUN_SERVICE=cloudtutor-backend
# ARTIFACT_REPO=cloudtutor-images
# IMAGE_NAME=cloudtutor-backend

# CloudTutor backend runtime
CLOUDTUTOR_APP_NAME=cloudtutor-backend
CLOUDTUTOR_AGENT_VOICE=Puck
CLOUDTUTOR_AGENT_LANGUAGE=en-US
CLOUDTUTOR_AUDIO_DOWNLINK_MODE=binary
# CLOUDTUTOR_RESPONSE_MODE=audio
# Voice endpointing tuneables for better full-utterance capture.
# CLOUDTUTOR_VAD_PREFIX_PADDING_MS=200
# CLOUDTUTOR_VAD_SILENCE_DURATION_MS=500
CLOUDTUTOR_COMPUTER_USE_MODEL=gemini-2.5-computer-use-preview-10-2025
CLOUDTUTOR_COMPUTER_USE_PROVIDER=browserbase

# Authentication for future ADK runtime sessions
GOOGLE_GENAI_USE_VERTEXAI=0
GOOGLE_API_KEY=PASTE_YOUR_GOOGLE_API_KEY
# Optional alias used by direct Computer Use worker path:
# GEMINI_API_KEY=PASTE_YOUR_GOOGLE_API_KEY

# Browserbase (required for CloudTutor computer-use walkthroughs)
BROWSERBASE_API_KEY=PASTE_BROWSERBASE_API_KEY
BROWSERBASE_PROJECT_ID=PASTE_BROWSERBASE_PROJECT_ID

# Session 09 persistence (local + optional Firestore mirror)
# CLOUDTUTOR_SESSION_STORE_DIR=docs/sessions
# CLOUDTUTOR_SESSION_TRANSCRIPT_LIMIT=120000
# CLOUDTUTOR_FIRESTORE_ENABLED=0
# CLOUDTUTOR_FIRESTORE_COLLECTION=cloudtutor_sessions
# FIRESTORE_PROJECT_ID=cloudtutor-490215
# CLOUDTUTOR_FIRESTORE_FAILURE_LIMIT=5

# Session 09 artifact cloud storage (optional)
# CLOUDTUTOR_ARTIFACT_GCS_BUCKET=cloudtutor-challenge.firebasestorage.app
# CLOUDTUTOR_ARTIFACT_GCS_PREFIX=tutorial-artifacts
# CLOUDTUTOR_ARTIFACT_GCS_PROJECT=cloudtutor-490215

# Live model override (optional)
# CLOUDTUTOR_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# Vertex AI alternative
# GOOGLE_GENAI_USE_VERTEXAI=1
# GOOGLE_CLOUD_PROJECT=cloudtutor-490215
# GOOGLE_CLOUD_LOCATION=us-central1
# VERTEXAI_PROJECT=cloudtutor-490215
# VERTEXAI_LOCATION=us-central1

# Firebase project defaults (for upcoming persistence/frontend sessions)
FIREBASE_PROJECT_ID=cloudtutor-challenge
NEXT_PUBLIC_FIREBASE_PROJECT_ID=cloudtutor-challenge
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=cloudtutor-challenge.firebaseapp.com
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=cloudtutor-challenge.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=PASTE_SENDER_ID
NEXT_PUBLIC_FIREBASE_APP_ID=PASTE_APP_ID
NEXT_PUBLIC_FIREBASE_API_KEY=PASTE_WEB_API_KEY
