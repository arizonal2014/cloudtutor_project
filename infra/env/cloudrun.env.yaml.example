CLOUDTUTOR_APP_NAME: cloudtutor-backend
CLOUDTUTOR_AUDIO_DOWNLINK_MODE: binary
CLOUDTUTOR_RESPONSE_MODE: audio

CLOUDTUTOR_VAD_START_SENSITIVITY: high
CLOUDTUTOR_VAD_END_SENSITIVITY: high
CLOUDTUTOR_VAD_PREFIX_PADDING_MS: "200"
CLOUDTUTOR_VAD_SILENCE_DURATION_MS: "350"

CLOUDTUTOR_COMPUTER_USE_PROVIDER: browserbase
CLOUDTUTOR_COMPUTER_USE_MODEL: gemini-2.5-computer-use-preview-10-2025

BROWSERBASE_API_KEY: "replace-with-browserbase-api-key"
BROWSERBASE_PROJECT_ID: "replace-with-browserbase-project-id"

# Session persistence and artifact paths in Cloud Run writable /tmp volume.
CLOUDTUTOR_SESSION_STORE_DIR: /tmp/cloudtutor/sessions
CLOUDTUTOR_ARTIFACT_DIR: /tmp/cloudtutor/artifacts

# Optional persistence mirrors.
# Keep disabled by default unless Firestore default database is already created.
CLOUDTUTOR_FIRESTORE_ENABLED: "0"
CLOUDTUTOR_FIRESTORE_COLLECTION: cloudtutor_sessions
FIRESTORE_PROJECT_ID: cloudtutor-490215
CLOUDTUTOR_FIRESTORE_FAILURE_LIMIT: "5"

# Optional artifact upload mirror.
CLOUDTUTOR_ARTIFACT_GCS_BUCKET: cloudtutor-challenge.firebasestorage.app
CLOUDTUTOR_ARTIFACT_GCS_PREFIX: tutorial-artifacts
CLOUDTUTOR_ARTIFACT_GCS_PROJECT: cloudtutor-490215

# Recommended provider mode for production quota and auth.
GOOGLE_GENAI_USE_VERTEXAI: "1"
GOOGLE_CLOUD_PROJECT: cloudtutor-490215
GOOGLE_CLOUD_LOCATION: us-central1
VERTEXAI_PROJECT: cloudtutor-490215
VERTEXAI_LOCATION: us-central1

# If you prefer AI Studio key mode instead of Vertex, use:
# GOOGLE_GENAI_USE_VERTEXAI: "0"
# GOOGLE_API_KEY: "replace-with-api-key"
